# Backend Configuration
BACKEND_PORT=8000
FRONTEND_PORT=3000

# LLM Provider: "ollama" or "claude" (claude uses Claude Code CLI — no API key needed)
LLM_PROVIDER=ollama

# Ollama Configuration (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://192.168.100.124:11434
OLLAMA_MODEL_PROPONENT=glm-4:9b-chat-q4_K_M
OLLAMA_MODEL_OPPONENT=glm-4:9b-chat-q4_K_M
OLLAMA_MODEL_MODERATOR=glm-4:9b-chat-q4_K_M

# Debate Rules
MAX_TURNS=10
WORD_LIMIT=75

# Email Configuration (optional — for sending debate summaries)
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-smtp-password
